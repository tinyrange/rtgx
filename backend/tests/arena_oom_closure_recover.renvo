package main

func arenaAllocateClosures() {
	var callback func() int
	i := 0
	for i < 64 {
		value := i
		callback = func() int {
			return value
		}
		i++
	}
	print(callback())
	print("FAIL\n")
}

func appMain() (status int) {
	status = 1
	defer func() {
		if recover() != nil {
			print("PASS\n")
			status = 0
		}
	}()
	arenaAllocateClosures()
	return
}
