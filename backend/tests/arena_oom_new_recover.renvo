package main

type arenaOOMNode struct {
	next  *arenaOOMNode
	value int
}

func arenaAllocateNodes() {
	var head *arenaOOMNode
	i := 0
	for i < 64 {
		node := new(arenaOOMNode)
		node.next = head
		node.value = i
		head = node
		i++
	}
	print("FAIL\n")
}

func appMain() (status int) {
	status = 1
	defer func() {
		if recover() != nil {
			print("PASS\n")
			status = 0
		}
	}()
	arenaAllocateNodes()
	return
}
